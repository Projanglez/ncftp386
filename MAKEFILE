# =============================================================================
# NCFTP386 - Norton Commander FTP Client for MS-DOS 386
# Open Watcom Makefile (wmake)
# =============================================================================
#
# Prerequisites:
#   - Open Watcom C/C++ installed and in PATH (WATCOM env variable set)
#   - Official mTCP sources (version 2025-01-10) from the mTCP homepage:
#       http://www.brutman.com/mTCP/mTCP.html
#     Download the source archive and unpack it into ./mtcp/.
#
# Directory structure after unpacking:
#   ./mtcp/TCPLIB/   = TCP/IP library sources (.CPP)
#   ./mtcp/TCPINC/   = TCP/IP header files
#   ./mtcp/INCLUDE/  = cross-app shared includes
#   ./mtcp/APPS/FTP/ = reference FTP client (for looking things up)
#
# Build:  wmake
# Clean:  wmake clean
# =============================================================================

CC      = wcc
CPP     = wpp
ASM     = wasm
LINK    = wlink
RM      = del /Q /F

# -----------------------------------------------------------------------------
# Compiler flags
# -ml  = Large Memory Model
# -0   = 8086 instruction set (compatible with 8086/286/386+)
# -zu  = SS != DS (mandatory for mTCP!)
# -s   = no stack overflow check
# -ox  = maximum optimization
# -bt=dos = DOS target
# -zp1 = byte alignment in structs
# -ei  = enum as int
# -----------------------------------------------------------------------------
CFLAGS  = -ml -0 -zu -s -ox -bt=dos -zp1 -ei
INCPATH = -I./src -I./mtcp/TCPINC -I./mtcp/INCLUDE

# -----------------------------------------------------------------------------
# Output
# -----------------------------------------------------------------------------
TARGET  = NCFTP386.EXE
MAPFILE = NCFTP386.MAP

# -----------------------------------------------------------------------------
# Application objects
# -----------------------------------------------------------------------------
APP_OBJS = &
    src\ncftp.obj &
    src\tui.obj &
    src\panel.obj &
    src\lpanel.obj &
    src\rpanel.obj &
    src\ftpcli.obj &
    src\dialog.obj &
    src\viewer.obj &
    src\editor.obj &
    src\dircopy.obj &
    src\connsave.obj &
    src\i18n.obj

# -----------------------------------------------------------------------------
# mTCP core objects (from TCPLIB/)
# See mtcp\APPS\FTP\makefile for the exact file list.
# File list for the official 2025-01-10 version. Compared to older mTCP
# versions, trace.obj was added as a fixed dependency of the FTP client.
# -----------------------------------------------------------------------------
MTCP_OBJS = &
    mtcp\TCPLIB\arp.obj &
    mtcp\TCPLIB\dns.obj &
    mtcp\TCPLIB\eth.obj &
    mtcp\TCPLIB\ip.obj &
    mtcp\TCPLIB\ipasm.obj &
    mtcp\TCPLIB\packet.obj &
    mtcp\TCPLIB\tcp.obj &
    mtcp\TCPLIB\tcpsockm.obj &
    mtcp\TCPLIB\timer.obj &
    mtcp\TCPLIB\trace.obj &
    mtcp\TCPLIB\udp.obj &
    mtcp\TCPLIB\utils.obj

ALL_OBJS = $(APP_OBJS) $(MTCP_OBJS)

# -----------------------------------------------------------------------------
# Main target
# -----------------------------------------------------------------------------
all: $(TARGET) .SYMBOLIC

$(TARGET): $(ALL_OBJS)
    $(LINK) &
        system dos &
        option stack=32768 &
        option map=$(MAPFILE) &
        name $(TARGET) &
        file { $(ALL_OBJS) }
    @echo.
    @echo Build successful: $(TARGET)

# -----------------------------------------------------------------------------
# Application sources
# -----------------------------------------------------------------------------
# -zt256: put the large panel globals (g_left/g_right, ~25 KB each) into
# FAR data segments so DGROUP (64 KB, large model) doesn't overflow.
src\ncftp.obj: src\ncftp.cpp src\tui.h src\panel.h src\lpanel.h src\rpanel.h src\ftpcli.h src\keymap.h src\dialog.h src\viewer.h src\editor.h src\dircopy.h src\connsave.h src\i18n.h src\umlaut.h
    $(CPP) $(CFLAGS) -zt256 $(INCPATH) -fo=$@ $[@

src\tui.obj: src\tui.cpp src\tui.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\panel.obj: src\panel.cpp src\panel.h src\tui.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\lpanel.obj: src\lpanel.cpp src\lpanel.h src\panel.h src\tui.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\rpanel.obj: src\rpanel.cpp src\rpanel.h src\panel.h src\tui.h src\ftpcli.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\ftpcli.obj: src\ftpcli.cpp src\ftpcli.h src\ncftp.cfg src\i18n.h
    $(CPP) $(CFLAGS) -DCFG_H="ncftp.cfg" $(INCPATH) -fo=$@ $[@

src\dialog.obj: src\dialog.cpp src\dialog.h src\tui.h src\keymap.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\viewer.obj: src\viewer.cpp src\viewer.h src\tui.h src\keymap.h src\dialog.h src\i18n.h src\umlaut.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\editor.obj: src\editor.cpp src\editor.h src\tui.h src\keymap.h src\dialog.h src\i18n.h src\umlaut.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\dircopy.obj: src\dircopy.cpp src\dircopy.h src\ftpcli.h src\panel.h src\rpanel.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\connsave.obj: src\connsave.cpp src\connsave.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\i18n.obj: src\i18n.cpp src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

# -----------------------------------------------------------------------------
# mTCP core sources (TCPLIB/)
# Flags: additionally -I./mtcp/TCPLIB for internal mTCP includes
# -----------------------------------------------------------------------------
# -DCFG_H="ncftp.cfg": every mTCP header does `#include CFG_H`.
# ncftp.cfg lives in src/ and is found via -I./src (in INCPATH).
# No -zp2: since the mTCP reference build is warning-free with
# -zp2 -zpw -we, -zp2 doesn't add any padding -> the layout is identical
# to our -zp1. This keeps all objects (including ftpcli.obj with inline
# methods from tcp.h) consistent at -zp1.
#
# IMPORTANT: mTCP is built with -0 (8086), NOT with -3 (386)!
# packet.cpp::receiver() is the receive callback invoked by the packet
# driver via FAR CALL. It has a HAND-WRITTEN assembler epilogue
# (pop ax/ax/es/ds/di/si/bp/bx/bx/dx/cx/ax; retf = 12 words + retf) that
# exactly matches the 8086 __interrupt prologue (push ax/cx/dx/bx/sp/bp/si/di +
# ds/es + 2 pad = 12 words). With -3, the compiler prologue ADDITIONALLY
# saves the 386 segment registers FS and GS (pusha+ds+es+fs+gs+sub sp,4 =
# 14 words), which the fixed epilogue does NOT pop back -> after the 12
# pops, FS/GS are still left on the stack -> retf reads garbage as the
# return address -> a hard hang in interrupt context on the FIRST received
# packet (Ctrl+Alt+Del dead). Verified via wdis disassembly. The mTCP
# reference (APPS/FTP/MAKEFILE) also builds with -0. 8086 code runs fine
# on the 386; only our own app code uses -3. (ipasm.asm: already wasm -0,
# see below.)
MCFLAGS = -ml -0 -zu -s -ox -bt=dos -zp1 -ei
MFLAGS  = $(MCFLAGS) -DCFG_H="ncftp.cfg" -I./mtcp/TCPLIB $(INCPATH)

mtcp\TCPLIB\arp.obj: mtcp\TCPLIB\arp.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\dns.obj: mtcp\TCPLIB\dns.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\eth.obj: mtcp\TCPLIB\eth.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\ip.obj: mtcp\TCPLIB\ip.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

# ipasm.asm selects the memory model via __LARGE__ (set by wasm -ml).
mtcp\TCPLIB\ipasm.obj: mtcp\TCPLIB\ipasm.asm
    $(ASM) -0 -ml -fo=$@ $[@

mtcp\TCPLIB\packet.obj: mtcp\TCPLIB\packet.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\tcp.obj: mtcp\TCPLIB\tcp.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\tcpsockm.obj: mtcp\TCPLIB\tcpsockm.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\timer.obj: mtcp\TCPLIB\timer.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\trace.obj: mtcp\TCPLIB\trace.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\udp.obj: mtcp\TCPLIB\udp.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\utils.obj: mtcp\TCPLIB\utils.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

# -----------------------------------------------------------------------------
# Cleanup
# -----------------------------------------------------------------------------
clean: .SYMBOLIC
    -$(RM) src\*.obj 2>nul
    -$(RM) mtcp\TCPLIB\*.obj 2>nul
    -$(RM) $(TARGET) 2>nul
    -$(RM) $(MAPFILE) 2>nul
    @echo Clean complete.
