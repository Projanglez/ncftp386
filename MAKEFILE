# =============================================================================
# NCFTP386 - Norton Commander FTP Client for MS-DOS 386
# Open Watcom Makefile (wmake)
# =============================================================================
#
# Voraussetzungen:
#   - Open Watcom C/C++ installiert und im PATH (WATCOM env-Variable gesetzt)
#   - mTCP-Quellen via: git clone https://github.com/retrohun/mTCP mtcp
#
# Verzeichnisstruktur nach git clone:
#   ./mtcp/TCPLIB/   = TCP/IP Bibliotheks-Quellen (.CPP)
#   ./mtcp/TCPINC/   = TCP/IP Header-Dateien
#   ./mtcp/INCLUDE/  = App-uebergreifende Includes
#   ./mtcp/APPS/FTP/ = Referenz-FTP-Client (zum Nachschlagen)
#
# Build:  wmake
# Clean:  wmake clean
# =============================================================================

CC      = wcc
CPP     = wpp
ASM     = wasm
LINK    = wlink
RM      = del /Q /F

# -----------------------------------------------------------------------------
# Compiler-Flags
# -ml  = Large Memory Model
# -3   = 386-Instruktionssatz
# -zu  = SS != DS (zwingend fuer mTCP!)
# -s   = kein Stack-Overflow-Check
# -ox  = maximale Optimierung
# -bt=dos = DOS-Target
# -zp1 = Byte-Alignment in Structs
# -ei  = enum als int
# -----------------------------------------------------------------------------
CFLAGS  = -ml -3 -zu -s -ox -bt=dos -zp1 -ei
INCPATH = -I./src -I./mtcp/TCPINC -I./mtcp/INCLUDE

# -----------------------------------------------------------------------------
# Ausgabe
# -----------------------------------------------------------------------------
TARGET  = NCFTP.EXE
MAPFILE = NCFTP.MAP

# -----------------------------------------------------------------------------
# Applikations-Objekte
# -----------------------------------------------------------------------------
APP_OBJS = &
    src\ncftp.obj &
    src\tui.obj &
    src\panel.obj &
    src\lpanel.obj &
    src\rpanel.obj &
    src\ftpcli.obj &
    src\dialog.obj &
    src\viewer.obj &
    src\dircopy.obj &
    src\connsave.obj &
    src\i18n.obj

# -----------------------------------------------------------------------------
# mTCP-Kern-Objekte (aus TCPLIB/)
# Orientiere dich an mtcp\APPS\FTP\makefile fuer die genaue Dateiliste.
# Typische Kernbestandteile der 2015er Version:
# -----------------------------------------------------------------------------
MTCP_OBJS = &
    mtcp\TCPLIB\arp.obj &
    mtcp\TCPLIB\dns.obj &
    mtcp\TCPLIB\eth.obj &
    mtcp\TCPLIB\ip.obj &
    mtcp\TCPLIB\ipasm.obj &
    mtcp\TCPLIB\packet.obj &
    mtcp\TCPLIB\tcp.obj &
    mtcp\TCPLIB\tcpsockm.obj &
    mtcp\TCPLIB\timer.obj &
    mtcp\TCPLIB\udp.obj &
    mtcp\TCPLIB\utils.obj

ALL_OBJS = $(APP_OBJS) $(MTCP_OBJS)

# -----------------------------------------------------------------------------
# Haupt-Target
# -----------------------------------------------------------------------------
all: $(TARGET) .SYMBOLIC

$(TARGET): $(ALL_OBJS)
    $(LINK) &
        system dos &
        option stack=32768 &
        option map=$(MAPFILE) &
        name $(TARGET) &
        file { $(ALL_OBJS) }
    @echo.
    @echo Build erfolgreich: $(TARGET)

# -----------------------------------------------------------------------------
# Applikations-Quellen
# -----------------------------------------------------------------------------
# -zt256: grosse Panel-Globals (g_left/g_right, ~25 KB je) in FAR-Datensegmente
# legen, damit DGROUP (64 KB, large model) nicht ueberlaeuft.
src\ncftp.obj: src\ncftp.cpp src\tui.h src\panel.h src\lpanel.h src\rpanel.h src\ftpcli.h src\keymap.h src\dialog.h src\viewer.h src\dircopy.h src\connsave.h src\i18n.h
    $(CPP) $(CFLAGS) -zt256 $(INCPATH) -fo=$@ $[@

src\tui.obj: src\tui.cpp src\tui.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\panel.obj: src\panel.cpp src\panel.h src\tui.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\lpanel.obj: src\lpanel.cpp src\lpanel.h src\panel.h src\tui.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\rpanel.obj: src\rpanel.cpp src\rpanel.h src\panel.h src\tui.h src\ftpcli.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\ftpcli.obj: src\ftpcli.cpp src\ftpcli.h src\ncftp.cfg src\i18n.h
    $(CPP) $(CFLAGS) -DCFG_H="ncftp.cfg" $(INCPATH) -fo=$@ $[@

src\dialog.obj: src\dialog.cpp src\dialog.h src\tui.h src\keymap.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\viewer.obj: src\viewer.cpp src\viewer.h src\tui.h src\keymap.h src\dialog.h src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\dircopy.obj: src\dircopy.cpp src\dircopy.h src\ftpcli.h src\panel.h src\rpanel.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\connsave.obj: src\connsave.cpp src\connsave.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

src\i18n.obj: src\i18n.cpp src\i18n.h
    $(CPP) $(CFLAGS) $(INCPATH) -fo=$@ $[@

# -----------------------------------------------------------------------------
# mTCP-Kern-Quellen (TCPLIB/)
# Flags: zusaetzlich -I./mtcp/TCPLIB fuer interne mTCP-Includes
# -----------------------------------------------------------------------------
# -DCFG_H="ncftp.cfg": jeder mTCP-Header macht `#include CFG_H`.
# ncftp.cfg liegt in src/ und wird ueber -I./src (in INCPATH) gefunden.
# Kein -zp2: da der mTCP-Referenz-Build mit -zp2 -zpw -we warnungsfrei ist,
# fuegt -zp2 keinerlei Padding hinzu -> Layout ist identisch zu unserem
# -zp1. So bleiben alle Objekte (auch ftpcli.obj mit inline-Methoden aus
# tcp.h) bei -zp1 konsistent.
#
# WICHTIG: mTCP wird mit -0 (8086) gebaut, NICHT mit -3 (386)!
# packet.cpp::receiver() ist der vom Packet-Driver per FAR CALL aufgerufene
# Empfangs-Callback. Er hat einen VON HAND geschriebenen Assembler-Epilog
# (pop ax/ax/es/ds/di/si/bp/bx/bx/dx/cx/ax; retf = 12 Worte + retf), der
# exakt zum 8086-__interrupt-Prolog passt (push ax/cx/dx/bx/sp/bp/si/di +
# ds/es + 2 Pad = 12 Worte). Mit -3 rettet der Compiler-Prolog ZUSAETZLICH
# die 386-Segmentregister FS und GS (pusha+ds+es+fs+gs+sub sp,4 = 14 Worte),
# die der feste Epilog NICHT zurueckholt -> nach den 12 pops liegen FS/GS
# noch auf dem Stack -> retf liest Muell als Ruecksprungadresse -> harter
# Haenger im Interrupt-Kontext beim ERSTEN empfangenen Paket (Strg+Alt+Entf
# tot). Verifiziert per wdis-Disassembly. Die mTCP-Referenz (APPS/FTP/
# MAKEFILE) baut ebenfalls mit -0. 8086-Code laeuft problemlos auf dem 386;
# nur unser eigener App-Code nutzt -3. (ipasm.asm: bereits wasm -0, s.u.)
MCFLAGS = -ml -0 -zu -s -ox -bt=dos -zp1 -ei
MFLAGS  = $(MCFLAGS) -DCFG_H="ncftp.cfg" -I./mtcp/TCPLIB $(INCPATH)

mtcp\TCPLIB\arp.obj: mtcp\TCPLIB\arp.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\dns.obj: mtcp\TCPLIB\dns.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\eth.obj: mtcp\TCPLIB\eth.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\ip.obj: mtcp\TCPLIB\ip.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

# ipasm.asm waehlt das Speichermodell ueber __LARGE__ (von wasm -ml gesetzt).
mtcp\TCPLIB\ipasm.obj: mtcp\TCPLIB\ipasm.asm
    $(ASM) -0 -ml -fo=$@ $[@

mtcp\TCPLIB\packet.obj: mtcp\TCPLIB\packet.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\tcp.obj: mtcp\TCPLIB\tcp.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\tcpsockm.obj: mtcp\TCPLIB\tcpsockm.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\timer.obj: mtcp\TCPLIB\timer.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\udp.obj: mtcp\TCPLIB\udp.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

mtcp\TCPLIB\utils.obj: mtcp\TCPLIB\utils.cpp src\ncftp.cfg
    $(CPP) $(MFLAGS) -fo=$@ $[@

# -----------------------------------------------------------------------------
# Aufraeumen
# -----------------------------------------------------------------------------
clean: .SYMBOLIC
    -$(RM) src\*.obj 2>nul
    -$(RM) mtcp\TCPLIB\*.obj 2>nul
    -$(RM) $(TARGET) 2>nul
    -$(RM) $(MAPFILE) 2>nul
    @echo Clean abgeschlossen.
