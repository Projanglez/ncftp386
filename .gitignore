# mTCP - externe Abhaengigkeit, wird per git clone geholt
# (siehe CLAUDE.md: git clone https://github.com/retrohun/mTCP mtcp)
mtcp/

# Compiler-Zwischenergebnisse
src/*.obj
*.obj

# Build-Artefakte
*.EXE
*.MAP
*.exe
*.map

# Release-Pakete (gehoeren in GitHub-Releases, nicht ins Repo)
*.zip

# Laufzeitdatei: gemerkte FTP-Verbindung (wird neben der EXE angelegt)
*.SAV
*.sav

# Watcom temporaere Dateien
*.ERR
*.err

# Editor- und Tooling-Konfiguration (lokal, gehoert nicht ins Repo)
.claude/
.vscode/
